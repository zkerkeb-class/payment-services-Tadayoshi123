{
  "name": "supervia-payment-service",
  "version": "1.0.0",
  "description": "Microservice pour la gestion des paiements, abonnements et facturation avec Stripe pour SupervIA",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "swagger:gen": "node scripts/generate-swagger.js",
    "setup": "npm install && npm run swagger:gen",
    "docker:build": "docker build -t supervia-payment-service .",
    "docker:run": "docker run -p 3006:3006 --env-file .env supervia-payment-service"
  },
  "keywords": [
    "supervia",
    "microservice",
    "payment",
    "stripe",
    "subscription"
  ],
  "author": "SupervIA Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-jwt": "^8.4.1",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "pino": "^8.21.0",
    "pino-http": "^9.0.0",
    "prom-client": "^15.1.2",
    "stripe": "^15.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zkerkeb-class/payment-services-Tadayoshi123"
  }
}
