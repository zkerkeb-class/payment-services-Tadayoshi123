# =============================================================================
# 💳 SERVICE DE PAIEMENT SUPERVIA - CONFIGURATION D'EXEMPLE
# =============================================================================
# Ce fichier sert de modèle pour votre propre fichier .env.
# Copiez ce fichier en .env et remplacez les valeurs ci-dessous.
# NE JAMAIS COMMITER VOTRE FICHIER .env DANS LE DÉPÔT GIT.

# =============================================
# 📡 CONFIGURATION SERVEUR
# =============================================
NODE_ENV=development
PORT=3006
API_VERSION=v1
API_URL=http://localhost:3006

# =============================================
# 🔑 SÉCURITÉ & AUTHENTIFICATION
# =============================================
# SECRET JWT PARTAGÉ - CRITIQUE
# Utilisé pour signer les tokens pour la communication de service à service.
# Ce secret DOIT être identique sur TOUS les microservices de l'écosystème.
JWT_SECRET=votre_secret_jwt_partage_long_et_aleatoire_ici

# =============================================
# 🌐 URLS & CORS
# =============================================
# Domaines autorisés à appeler ce service. Séparez les URLs par des virgules.
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# URL du frontend pour les redirections après une session de paiement Stripe.
FRONTEND_URL=http://localhost:3000

# =============================================
# 💳 CONFIGURATION STRIPE
# =============================================
# Vos clés API Stripe (disponibles dans votre dashboard Stripe > Développeurs > Clés API).
# Utilisez vos clés de test (sk_test_...) pour le développement.
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret du webhook pour vérifier l'authenticité des événements envoyés par Stripe.
# 1. Dans votre dashboard Stripe > Développeurs > Webhooks, créez un nouveau point de terminaison.
# 2. Pour le développement local, utilisez le CLI Stripe : `stripe listen --forward-to localhost:3006/api/v1/webhooks/stripe`
# 3. Le CLI vous donnera un secret de signature de webhook (whsec_...). Copiez-le ici.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================
# 🔗 URLS DES SERVICES DÉPENDANTS
# =============================================
# URLs pour la communication inter-services.
# En environnement Docker, utilisez les noms de service (ex: http://supervia-db-service:3002).
DB_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3005

# URL du service d'authentification. Utilisé pour récupérer les clés publiques (JWKS)
# afin de valider les tokens JWT des utilisateurs.
AUTH_SERVICE_URL=http://localhost:3001/api/v1

# =============================================
# 🔧 DÉVELOPPEMENT & LOGS
# =============================================
LOG_LEVEL=debug
ENABLE_SWAGGER=true 